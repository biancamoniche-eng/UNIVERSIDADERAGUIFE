rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // documento de perfil do usuário autenticado (uid == documento)
    function myUserDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    function myRole() {
      return signedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
             ? myUserDoc().role : 'none';
    }
    function isRH()      { return myRole() == 'rh'; }
    function isManager() { return myRole() == 'manager'; }

    // ---- Estado consolidado do sistema ----
    // Leitura: qualquer usuário autenticado (o app filtra o que cada perfil vê).
    // Escrita: RH e Gestor (gestor confirma presença/edita a própria equipe pelo app).
    match /configuracoes/{doc} {
      allow read:  if signedIn();
      allow write: if isRH() || isManager();
    }

    // ---- Documentos de usuário (perfil/uid) ----
    // Cada um lê/cria o próprio doc; RH gerencia todos.
    match /usuarios/{uid} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if isRH() || request.auth.uid == uid;
    }

    // ---- Metadados de arquivos ----
    match /arquivos/{id} {
      allow read:  if signedIn();
      allow write: if isRH() || isManager();
    }

    // ---- Logs / auditoria ----
    // Qualquer autenticado pode registrar um log; só RH lê o histórico completo.
    match /logs/{id} {
      allow create: if signedIn();
      allow read:   if isRH();
      allow update, delete: if false;
    }

    // Bloqueia o resto por padrão (banco NÃO público).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
